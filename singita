<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'Inter', sans-serif;
  background: #ffe6f0; /* LIGHT PINK BACKGROUND */
  color: #2d2d2d;
}

/* TOP SECTION */
header {
  text-align: center;
  padding: 40px 20px;
  background: linear-gradient(135deg, #ffb6c1, #ffd6e7);
}

/* PROFILE IMAGE */
.profile-img {
  width: 140px;
  height: 140px;
  border-radius: 50%;
  object-fit: cover;
  border: 5px solid white;
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
  margin-bottom: 15px;
}

h1 {
  margin: 10px 0 5px;
  font-size: 32px;
}

p {
  margin: 5px;
}

/* NAV CARDS */
.nav {
  display: flex;
  justify-content: center;
  gap: 15px;
  flex-wrap: wrap;
  margin-top: 20px;
}

.nav button {
  background: white;
  border: none;
  padding: 12px 18px;
  border-radius: 20px;
  cursor: pointer;
  font-weight: 600;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  transition: 0.3s;
}

.nav button:hover {
  transform: translateY(-3px);
  background: #ffd1dc;
}

/* CONTENT BOX */
.section {
  max-width: 900px;
  margin: 30px auto;
  background: white;
  padding: 25px;
  border-radius: 15px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.08);
  display: none;
}

.section.active {
  display: block;
}

h2 {
  border-bottom: 2px solid #ffb6c1;
  padding-bottom: 8px;
}

/* LIST */
ul {
  line-height: 1.8;
}
</style>
